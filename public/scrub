$workDir = "$env:TEMP\OfficeScrubber"
$zipFile = "$workDir\scrub.zip"
$url = "https://www.tc-info.com.tw/public/Scrub.zip"

if (Test-Path $workDir) { Remove-Item $workDir -Recurse -Force }
New-Item -ItemType Directory -Path $workDir | Out-Null

Write-Host "Downloading uninstallation tool from server..." -ForegroundColor Cyan
Invoke-WebRequest -Uri $url -OutFile $zipFile

# 3. 解壓縮
Write-Host "Extracting files..." -ForegroundColor Cyan
Expand-Archive -Path $zipFile -DestinationPath $workDir -Force

# 4. 以管理員權限啟動
Write-Host "Launching Office Scrubber..." -ForegroundColor Yellow
Start-Process -FilePath "cmd.exe" -ArgumentList "/c `"$workDir\OfficeScrubberAIO.cmd`"" -Verb RunAs